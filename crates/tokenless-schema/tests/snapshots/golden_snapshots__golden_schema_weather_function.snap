{
  "type": "function",
  "function": {
    "name": "get_weather",
    "parameters": {
      "type": "object",
      "properties": {
        "location": {
          "type": "string",
          "description": "The city name, ZIP code, or geographic coordinates for which to retrieve weather data. Examples include 'San Francisco, CA', '94105', or '37.7749,-122.4194'."
        },
        "units": {
          "type": "string",
          "description": "The temperature unit system to use for the returned weather data. Celsius is the default for most international locations, while Fahrenheit is common in the Uni",
          "enum": [
            "celsius",
            "fahrenheit",
            "kelvin"
          ]
        },
        "forecast_days": {
          "type": "integer",
          "description": "Number of days to include in the forecast, ranging from 1 to 14 days ahead. Defaults to 1 when not specified.",
          "minimum": 1,
          "maximum": 14
        },
        "include_hourly": {
          "type": "boolean",
          "default": false,
          "description": "Whether to include hour-by-hour weather data in the response for each forecast day. Enabling this flag significantly increases response size."
        }
      },
      "required": [
        "location"
      ]
    },
    "description": "Retrieves current weather conditions and forecast data for a given location. This function supports city names, ZIP codes, and geographic coordinates."
  }
